# === Docker containers (services talk to each other by container name) ===
# Copy this file: cp .env.docker.example .env.docker

DATABASE_URL=postgres://postgres:postgres@postgresDB:5432/go_ticket?sslmode=disable
REDIS_ADDR=redis:6379
KAFKA_ADDR=kafka:9092
RABBITMQ_URL="amqp://guest:guest@go_ticket_rabbitmq:5672/"